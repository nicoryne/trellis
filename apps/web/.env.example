# ─── Trellis Web Frontend ─────────────────────────────────────────────────────
#
# Copy this file to .env and fill in values for your environment.
# All variables prefixed with VITE_ are exposed to client-side code.

# ─── Backend API URL ──────────────────────────────────────────────────────────
# In development: leave empty or omit — Vite's proxy (vite.config.ts) forwards
# /api/* requests to http://localhost:3000 automatically.
#
# In production: set to the deployed backend URL (e.g. https://trellis-api.up.railway.app)
VITE_API_URL=
